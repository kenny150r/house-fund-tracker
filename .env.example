# Copy to .env and fill in. These are build-time public values (safe to expose:
# data is protected by Supabase Row-Level Security). Do NOT put service-role
# keys or data-provider API keys here.
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_PUBLISHABLE_ANON_KEY"

# Only needed for GitHub Pages *project* sites (https://user.github.io/<repo>/).
# Set to "/<repo>/". Leave unset for user/org pages or local dev.
# VITE_BASE="/house/"
